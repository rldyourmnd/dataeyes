# DataEyes API
DATAEYES_API_KEY=
DATAEYES_LLM_BASE_URL=https://cloud.dataeyes.ai/v1
DATAEYES_LLM_BASE_URL_BACKUP_CN=https://cloud-cn.shuyanai.com/v1
DATAEYES_LLM_BASE_URL_BACKUP_HK=https://cloud-hk.dataeyes.ai/v1
DATAEYES_SEARCH_BASE_URL=https://api.dataeyes.ai
DATAEYES_SEARCH_API_KEY=
DATAEYES_DEFAULT_MODEL=

# Model selection (comma-separated). Leave empty to test all discovered models.
BENCHMARK_MODEL_ALLOWLIST=
MAX_MODELS_PER_RUN=50

# LiteLLM Proxy (started via docker-compose, port 4000)
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MASTER_KEY=sk-local-litellm-change-me
LITELLM_CONFIG_PATH=generated/litellm.config.yaml

# Langfuse Cloud
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_OTEL_HOST=https://cloud.langfuse.com/api/public/otel

# Optional: LLM-as-judge
JUDGE_MODEL=

# App server
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
REQUEST_TIMEOUT_SECONDS=90
BENCHMARK_VERSION=2026-06-09.1

# PostgreSQL
POSTGRES_DB=benchmark
POSTGRES_USER=benchmark
POSTGRES_PASSWORD=benchmark
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://benchmark:benchmark@localhost:5432/benchmark

# RustFS / S3-compatible artifact storage
ARTIFACT_STORAGE_MODE=s3
RUSTFS_ENDPOINT_URL=http://localhost:9000
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_BUCKET=benchmark-artifacts
RUSTFS_REGION=us-east-1
LOCAL_ARTIFACT_DIR=artifacts
